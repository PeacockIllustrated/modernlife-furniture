# Modern Life Furniture, environment variables.
# Copy to .env.local and fill in. The public Supabase keys below are safe to
# expose to the browser; never put the service role key in this file.

# Supabase (public catalogue read, admin auth, enquiries and interest).
# Without these the site serves the static catalogue and the admin shows setup
# guidance. Use the project's URL and its anon (publishable) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Owner email notifications via Resend (optional). Enquiries and interest are
# still stored without these; only the notification email is skipped.
RESEND_API_KEY=
MLF_OWNER_EMAIL=
MLF_FROM_EMAIL=
