# Modern Life Furniture, environment variables.
# Copy to .env.local and fill in. The public keys below are safe to expose to
# the browser; the service role key and admin password must stay server-side.

# Supabase, public catalogue read (browser and server, anon role under RLS).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role, used only by the /api/admin server routes to manage
# the collection. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Owner dashboard sign-in (username and password gate).
ADMIN_USER=
ADMIN_PASSWORD=
# Optional: a separate secret to sign the session cookie. Falls back to the
# password when unset.
ADMIN_SESSION_SECRET=

# Owner email notifications via Resend (optional). Enquiries and interest are
# still stored without these; only the notification email is skipped.
RESEND_API_KEY=
MLF_OWNER_EMAIL=
MLF_FROM_EMAIL=
